# GamingBurst Panel — Environment Config
# Copy this file to .env and fill in your values

# Panel web server port
PANEL_PORT=7676

# Secret key for signing session tokens (change this to a random 64-char string)
SECRET_KEY=change_me_to_a_long_random_string_at_least_64_characters_long_please

# Path to the SQLite database file (relative to project root)
DB_PATH=./data/panel.db

# Default timezone injected into all spawned Java processes
DEFAULT_TZ=Asia/Kolkata

# Directory where server files are stored (absolute path recommended on VPS)
SERVERS_DIR=./servers

# bcrypt salt rounds (10 = ~100ms hash time, good balance)
BCRYPT_ROUNDS=10
